# ============================================================
# CaptionAI — Full Environment Variables
# ============================================================

# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_32_char_secret_here

# Database (PostgreSQL - use Supabase/Neon for free)
DATABASE_URL=postgresql://user:pass@host:5432/captionai

# Groq AI (Required) → https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key

# Google OAuth → https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth → https://github.com/settings/apps
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Razorpay → https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Cloudinary (Optional) → https://cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=caption_ai

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
